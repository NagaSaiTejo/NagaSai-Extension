{
  "manifest_version": 3,
  "name": "NagaSai AI",
  "version": "1.0.0",
  "description": "Your AI-powered reading assistant. Ask questions about any webpage using Gemini, GPT, Groq and more.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "shared.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "identity",
    "storage",
    "activeTab",
    "scripting",
    "sidePanel",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://text.pollinations.ai/*",
    "https://gen.pollinations.ai/*",
    "https://www.googleapis.com/*",
    "https://accounts.google.com/*"
  ],
  "oauth2": {
    "client_id": "814686278793-bodg7tep4a9oh16e63j9s9gc9grosc2e.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/userinfo.email",
      "https://www.googleapis.com/auth/userinfo.profile"
    ]
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*",
        "ui.css"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "commands": {
    "_toggle_stealth": {
      "suggested_key": {
        "default": "Alt+Shift+H"
      },
      "description": "Toggle NagaSai AI stealth mode (hide/show during screen sharing)"
    }
  }
}
